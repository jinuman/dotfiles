# ~/.gitconfig (디폴트: 개인 계정)
[user]
    name = Jinwoo Kim
    email = jinumandev@gmail.com

[core]
    editor = vim
    excludesfile = ~/.gitignore_global
    autocrlf = input
    quotePath = false

[color]
    ui = auto

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[credential]
    helper = osxkeychain

# git.baemin.in 호스트를 remote로 가진 repo에서만 회사 계정 적용
[includeIf "hasconfig:remote.*.url:*://*git.baemin.in*/**"]
    path = ~/.gitconfig.work

[alias]
    st = status
    co = checkout
    cb = checkout -b
    br = branch
    ci = commit
    last = log -1 HEAD
    lg = log --oneline --decorate --graph
    unstage = reset HEAD --
    cleanup = "!git branch --merged | grep -vE '^[*+]|master|develop' | xargs -r git branch -d"
